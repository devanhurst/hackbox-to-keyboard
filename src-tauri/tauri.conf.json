{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hackbox to Keyboard",
  "version": "3.2.4",
  "identifier": "com.hackbox.tokeyboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hackbox → Keyboard",
        "width": 480,
        "height": 720,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/devanhurst/hackbox-to-keyboard/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2REMzMTlEMThBMDYxN0MKUldSOFlhQVluVEhjUm1tN3pzUEErTmRvZEo4VG13SEQzZXFLQVpYVVVOTU8vUHNQeU1Jcld5bWMK"
    }
  }
}
